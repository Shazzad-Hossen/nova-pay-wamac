# Copy to .env.prod and edit values.

# Set to true only when DOMAIN_NAME is set and DNS points to VPS.
ENABLE_TLS=false

# If you have no domain yet, keep DOMAIN_NAME empty and set PUBLIC_IP.
DOMAIN_NAME=
PUBLIC_IP=143.198.68.126
ORIGIN=*

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=postgres

JWT_SECRET=change_me_internal_jwt_secret
JWT_KID=fintech-auth-v1
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7

LEDGER_TIMEOUT_MS=3000
FX_QUOTE_TTL_SECONDS=30
PAYROLL_WORKER_CONCURRENCY=5
PAYROLL_JOB_ATTEMPTS=5
PAYROLL_BACKOFF_MS=5000

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
